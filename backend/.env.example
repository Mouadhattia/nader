# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server port (default: 5000)
PORT=5000

# MongoDB connection string
# Local: mongodb://localhost:27017/audio-guest-book
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/audio-guest-book
MONGO_URI=mongodb://localhost:27017/audio-guest-book

# Frontend URL for CORS (adjust if your frontend runs on a different port)
FRONTEND_URL=http://localhost:3000
